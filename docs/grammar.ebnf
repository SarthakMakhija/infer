program
    = { top_level_statement } EOF ;

top_level_statement
    = declaration | function ;

statement
    = declaration | assignment | conditional | iteration | control_flow | function_call ";" | print ";" ;

declaration
    = "var" identifier [ ":" type ] [ "=" expression ] ";" ;

assignment
    = identifier "=" expression ";" ;

conditional
    = "if" expression "{" { statement } "}" [ else ] ;

else
    = "else" ( "{" { statement } "}" | conditional ) ;

iteration
    = "loop" "{" { statement } "}" ;

control_flow
    = "break" ";" ;

function
    = "fn" identifier "(" [ parameters ] ")" [ return_type ] "{" { statement } "}" ;

function_call
    = identifier "(" [ arguments ] ")" ;

print
    = "print" arguments

arguments
    = argument { "," argument } ;

argument
    = expression ;

parameters
    = parameter { "," parameter } ;

parameter
    = identifier [ ":" type ] ;

return_type
    = ":" type ;

identifier
    = IDENTIFIER ;

type
    = "i32" | "i64" | "string" | "bool" ;

expression
    = primary | unary | binary ;

primary
    = literal | identifier | "(" expression ")" | function_call ;

unary
    = ( "-" | "!" ) expression ;

binary
    = expression operator expression ;

operator
    = "+" | "-" | "*" | "/" | "==" | "!=" | ">" | ">=" | "<" | "<=" ;

literal
    = WHOLE_NUMBER | STRING_LITERAL | BOOLEAN_LITERAL ;